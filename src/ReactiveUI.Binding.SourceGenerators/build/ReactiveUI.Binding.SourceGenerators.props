<Project>

  <!--
    Controls whether the ReactiveUI.Binding source generator emits the
    // <auto-generated/> comment and #pragma warning disable header into its generated files.

    Default (true): the shipping convention — generated code carries the markers so compiler and
    analyzer diagnostics in generated files do not pollute consumer builds.

    Set to false to surface diagnostics in the generated code (e.g. when diagnosing the generator itself):

      <PropertyGroup>
        <ReactiveUIBindingEmitGeneratedCodeMarkers>false</ReactiveUIBindingEmitGeneratedCodeMarkers>
      </PropertyGroup>
  -->
  <PropertyGroup>
    <ReactiveUIBindingEmitGeneratedCodeMarkers Condition="'$(ReactiveUIBindingEmitGeneratedCodeMarkers)' == ''">true</ReactiveUIBindingEmitGeneratedCodeMarkers>
  </PropertyGroup>

  <!-- Make the property visible to the source generator via AnalyzerConfigOptions. -->
  <ItemGroup>
    <CompilerVisibleProperty Include="ReactiveUIBindingEmitGeneratedCodeMarkers" />
  </ItemGroup>

</Project>
